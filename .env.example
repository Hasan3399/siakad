# Salin file ini menjadi .env dan isi nilainya
# JANGAN upload file .env ke GitHub!

# Database - Railway akan otomatis mengisi ini
DATABASE_URL=mysql://user:password@host:port/database

# Atau isi manual:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=siakad
DB_USER=root
DB_PASSWORD=your_password

# JWT Secret - ganti dengan string acak yang panjang
JWT_SECRET=ganti_dengan_secret_key_yang_sangat_panjang_dan_acak_123456

# Port
PORT=3000
